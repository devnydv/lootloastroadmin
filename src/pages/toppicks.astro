---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getTopPicks } from '../lib/lootlo-queries';

const PAGE_SIZE = 4;

const { items: picks, hasMore } = await getTopPicks({ limit: PAGE_SIZE, offset: 0 });
---
<Layout
  title="Top Picks — LootLo"
  description="One best store per fashion category — chosen for value, returns policy, and genuine selection. Not the highest bidder."
  navBadge="Top Picks"
>
  <style is:global> >
    .page-hero { padding: 28px 20px 20px; }
    .page-hero h1 { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.5px; line-height: 1.15; margin-bottom: 8px; }
    .page-hero h1 em { font-style: normal; color: var(--gold); }
    .page-hero p { font-size: 0.85rem; color: var(--text-dim); line-height: 1.6; }
    .eyebrow { display: inline-flex; align-items: center; gap: 6px; background: var(--gold-glow); border: 1px solid var(--border-gold); color: var(--gold); font-size: 0.65rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 4px 10px; border-radius: 20px; margin-bottom: 14px; }
    .picks-list { padding: 0 20px; display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
    .pick-card { background: var(--surface); border: 1px solid var(--border-gold); border-radius: var(--radius); overflow: hidden; animation: slideUp 0.3s ease both; }
    .pick-header { background: var(--surface2); padding: 14px 18px; display: flex; align-items: center; gap: 14px; }
    .pick-emoji-wrap { width: 52px; height: 52px; border-radius: 12px; background: rgba(232, 201, 126, 0.08); border: 1px solid var(--border-gold); display: flex; align-items: center; justify-content: center; font-size: 1.7rem; flex-shrink: 0; }
    .pick-header-info { flex: 1; min-width: 0; }
    .pick-cat { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--gold); margin-bottom: 4px; }
    .pick-title { font-size: .93rem; font-weight: 700; line-height: 1.3; }
    .pick-desc { padding: 12px 18px 14px; font-size: .82rem; color: var(--text-dim); line-height: 1.6; border-bottom: 1px solid var(--border); }
    .pick-store-wrap { padding: 14px 18px; }
    .pick-store-label { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.2px; color: var(--muted); margin-bottom: 10px; }
    .why-section { padding: 0 20px 28px; }
    .why-section h2 { font-size: 1rem; font-weight: 700; margin-bottom: 14px; }
    .why-section h2 span { color: var(--gold); }
    .why-grid { display: flex; flex-direction: column; gap: 10px; }
    .why-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px 16px; display: flex; align-items: flex-start; gap: 12px; }
    .why-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 2px; }
    .why-title { font-size: .87rem; font-weight: 700; margin-bottom: 3px; }
    .why-desc { font-size: .75rem; color: var(--text-dim); line-height: 1.55; }
    .pick-skeleton { background: var(--surface); border: 1px solid var(--border-gold); border-radius: var(--radius); overflow: hidden; }
    .pick-sk-header { background: var(--surface2); padding: 14px 18px; display: flex; align-items: center; gap: 14px; }
    .sk-pe { width: 52px; height: 52px; border-radius: 12px; flex-shrink: 0; }
    .sk-pi { flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .sk-pl { height: 10px; border-radius: 4px; }
    .sk-pl.w55 { width: 55%; }
    .sk-pl.w80 { width: 80%; }
    .pick-sk-body { padding: 12px 18px; display: flex; flex-direction: column; gap: 10px; }
    .sk-ps { height: 56px; border-radius: var(--radius-sm); }

    @media (min-width: 768px) {
      .page-hero { padding: 40px 0 24px; text-align: center; display: flex; flex-direction: column; align-items: center; }
      .page-hero h1 { font-size: 2.6rem; }
      .page-hero p { max-width: 480px; font-size: 0.95rem; }
      .picks-list { padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; align-items: stretch; }
      .pick-card { display: flex; flex-direction: column; }
      .why-section { padding: 0; }
      .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }
    @media (min-width: 1100px) {
      .picks-list { grid-template-columns: repeat(3, 1fr); }
      .why-grid { grid-template-columns: repeat(4, 1fr); }
    }
  </style>

  <div class="page-hero">
    <div class="eyebrow">★ Editor's Choice</div>
    <h1>Our <em>Top Picks</em><br />Per Category</h1>
    <p>One best store per fashion category — chosen for value, returns policy, and genuine selection. Not the highest bidder.</p>
  </div>

  <div
    class="picks-list"
    id="picks-root"
    data-offset={picks.length}
    data-page-size={PAGE_SIZE}
    data-has-more={hasMore ? '1' : '0'}
  >
    {picks.map((p) => (
      <div class="pick-card">
        <div class="pick-header">
          <div class="pick-emoji-wrap">{p.emoji || '🛍️'}</div>
          <div class="pick-header-info">
            <div class="pick-cat">{p.cat || ''}</div>
            <div class="pick-title">{p.title || ''}</div>
          </div>
        </div>
        <div class="pick-desc">{p.description || ''}</div>
        <div class="pick-store-wrap">
          <div class="pick-store-label">★ Top Pick Store</div>
          <a class="store-btn is-top" href="#" data-url={p.store.url || '#'} data-name={p.store.name || ''}>
            <div class="store-left">
              <div class="store-icon">{p.store.icon || '🛒'}</div>
              <div>
                <div class="store-name">{p.store.name || ''} <span class="top-star">★</span></div>
                <div class="store-sub">{p.store.sub || ''}</div>
              </div>
            </div>
            <div class="store-arrow">›</div>
          </a>
        </div>
      </div>
    ))}
  </div>

  <div class="load-sentinel" id="load-sentinel"></div>
  <div class="load-more-spinner" id="load-spinner" style="display:none">
    <div class="spinner-dot"></div>
    <div class="spinner-dot"></div>
    <div class="spinner-dot"></div>
    Loading more…
  </div>

  <div class="why-section">
    <h2>How We <span>Choose</span></h2>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">🔍</div>
        <div>
          <div class="why-title">Manual Research</div>
          <div class="why-desc">Every Top Pick is hand-tested. We browse, filter, and check product quality before recommending.</div>
        </div>
      </div>
      <div class="why-card">
        <div class="why-icon">↩️</div>
        <div>
          <div class="why-title">Returns & Policies</div>
          <div class="why-desc">We favour stores with hassle-free returns, clear sizing guides, and responsive customer support.</div>
        </div>
      </div>
      <div class="why-card">
        <div class="why-icon">💰</div>
        <div>
          <div class="why-title">Real Value</div>
          <div class="why-desc">Top Picks aren't the priciest — they're the best balance of quality and price in that segment.</div>
        </div>
      </div>
      <div class="why-card">
        <div class="why-icon">🚫</div>
        <div>
          <div class="why-title">No Pay-to-Win</div>
          <div class="why-desc">Stores cannot pay to become a Top Pick. Our editorial choices stay independent of affiliate revenue.</div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const root = document.getElementById('picks-root')!;
    const pageSize = parseInt(root.dataset.pageSize || '4');
    let offset = parseInt(root.dataset.offset || '0');
    let hasMore = root.dataset.hasMore === '1';
    let loading = false;

    const spinner = document.getElementById('load-spinner') as HTMLElement;
    const sentinel = document.getElementById('load-sentinel')!;

    function bindStoreButtons() {
      root.querySelectorAll('.store-btn').forEach((btn) => {
        const el = btn as HTMLElement;
        if (el.dataset.bound) return;
        el.dataset.bound = '1';
        el.addEventListener('click', (e) => {
          e.preventDefault();
          (window as any).__lootlo?.openSheet?.(el.dataset.name, el.dataset.url);
        });
      });
    }
    bindStoreButtons();

    function appendPicks(items: any[]) {
      items.forEach((p) => {
        const el = document.createElement('div');
        el.className = 'pick-card';
        el.innerHTML = `
          <div class="pick-header">
            <div class="pick-emoji-wrap">${p.emoji || '🛍️'}</div>
            <div class="pick-header-info">
              <div class="pick-cat">${p.cat || ''}</div>
              <div class="pick-title">${p.title || ''}</div>
            </div>
          </div>
          <div class="pick-desc">${p.description || ''}</div>
          <div class="pick-store-wrap">
            <div class="pick-store-label">★ Top Pick Store</div>
            <a class="store-btn is-top" href="#" data-url="${p.store.url || '#'}" data-name="${p.store.name || ''}">
              <div class="store-left">
                <div class="store-icon">${p.store.icon || '🛒'}</div>
                <div>
                  <div class="store-name">${p.store.name || ''} <span class="top-star">★</span></div>
                  <div class="store-sub">${p.store.sub || ''}</div>
                </div>
              </div>
              <div class="store-arrow">›</div>
            </a>
          </div>`;
        root.appendChild(el);
      });
      bindStoreButtons();
    }

    async function loadMore() {
      if (loading || !hasMore) return;
      loading = true;
      spinner.style.display = 'flex';
      try {
        const res = await fetch(`/api/top-picks?offset=${offset}&limit=${pageSize}`);
        if (!res.ok) throw new Error('Failed to load more top picks');
        const data = await res.json();
        appendPicks(data.items);
        offset += data.items.length;
        hasMore = data.hasMore;
      } catch (err) {
        console.error('Load more top picks error:', err);
        hasMore = false;
      } finally {
        loading = false;
        spinner.style.display = 'none';
      }
    }

    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) loadMore();
    }, { rootMargin: '200px' });
    observer.observe(sentinel);
  </script>
</Layout>