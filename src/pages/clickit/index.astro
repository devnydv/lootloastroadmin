---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Lootlo Deals with one click" description="You are just one click away from the best fashion deals. Pre-filtered links to top stores ensure you land in the right section every time.">
    <div class="hero">
        <div class="hero-eyebrow">✦ Lootlo Deals</div>
        <h1>You are <em>Just one Click</em>,<br />away.</h1>
        <p class="hero-sub">
            Pre-filtered links to the best fashion stores. Every click lands you
            in the right section.
        </p>
    </div>

    <div class="chips-wrap">
        <div class="chips" id="category-chips">
            <div class="chip active" data-category="All">T-Shirts</div>
            <div class="chip" data-category="Fashion">👕 Formal Shirts</div>
            <div class="chip" data-category="Fashion">👕 Formal pants</div>
            <div class="chip" data-category="Footwear">👟 Shoes</div>
            <div class="chip" data-category="Beauty">🥿 Slippers</div>
            <div class="chip" data-category="Tech">💻 Tech</div>
            <div class="chip active" data-category="All"></div>
            <div class="chip" data-category="Fashion">👕 Fashion</div>
            <div class="chip" data-category="Footwear">👟 Footwear</div>
            <div class="chip" data-category="Beauty">🧴 Beauty</div>
            <div class="chip" data-category="Tech">💻 Tech</div>
            <div class="chip active" data-category="All">All Guides</div>
            <div class="chip" data-category="Fashion">👕 Fashion</div>
            <div class="chip" data-category="Footwear">👟 Footwear</div>
            <div class="chip" data-category="Beauty">🧴 Beauty</div>
            <div class="chip" data-category="Tech">💻 Tech</div>
            <div class="chip active" data-category="All">All Guides</div>
            <div class="chip" data-category="Fashion">👕 Fashion</div>
            <div class="chip" data-category="Footwear">👟 Footwear</div>
            <div class="chip" data-category="Beauty">🧴 Beauty</div>
            <div class="chip" data-category="Tech">💻 Tech</div>
            <div class="chip active" data-category="All">All Guides</div>
            <div class="chip" data-category="Fashion">👕 Fashion</div>
            <div class="chip" data-category="Footwear">👟 Footwear</div>
            <div class="chip" data-category="Beauty">🧴 Beauty</div>
            <div class="chip" data-category="Tech">💻 Tech</div>
            <div class="chip active" data-category="All">All Guides</div>
            <div class="chip" data-category="Fashion">👕 Fashion</div>
            <div class="chip" data-category="Footwear">👟 Footwear</div>
            <div class="chip" data-category="Beauty">🧴 Beauty</div>
            <div class="chip" data-category="Tech">💻 Tech</div>
        </div>
    </div>
    <div id="cards-root">
        <div class="section-label" data-label-for="mens">
            <h2>Men's Wear</h2><span id="count-mens">2 picks</span>
        </div>
        <div class="cards-list">
            <a href="#" class="card" data-card-id="mens-jeans">
            <div class="card-header">
                <div class="card-emoji-wrap">👖</div>
                <div class="card-header-info">
                    <div class="card-title">Men's Slim  Regular Jeans</div>
                    <div class="badges-row">
                        <span class="badge badge-hot">Trending</span>
                    </div>
                </div>
            </div>
            <div class="card-desc">From raw denim to stretch comfort fits — these links take you straight to the denim section.</div>
            </a>
            
           <a href="#" class="card" data-card-id="mens-jeans">
            <div class="card-header">
                <div class="card-emoji-wrap">👖</div>
                <div class="card-header-info">
                    <div class="card-title">Men's Slim  Regular Jeans</div>
                    <div class="badges-row">
                        <span class="badge badge-hot">Trending</span>
                    </div>
                </div>
            </div>
            <div class="card-desc">From raw denim to stretch comfort fits — these links take you straight to the denim section.</div>
            </a>
            <a href="#" class="card" data-card-id="mens-jeans">
            <div class="card-header">
                <div class="card-emoji-wrap">👖</div>
                <div class="card-header-info">
                    <div class="card-title">Men's Slim  Regular Jeans</div>
                    <div class="badges-row">
                        <span class="badge badge-hot">Trending</span>
                    </div>
                </div>
            </div>
            <div class="card-desc">From raw denim to stretch comfort fits — these links take you straight to the denim section.</div>
            </a>
            <a target="_blank" rel="noopener noreferrer" class="store-btn is-top"
                href="https://lootlo.site">
                <div class="store-left">
                    <div class="store-icon">🛒</div><div>
                        <div class="store-name">
                            Myntra<span class="top-star">★</span>
                        </div><div class="store-sub">
                            Huge collection, fast delivery
                        </div>
                    </div>
                </div><div class="store-arrow">
                    <span class="cost-indicator" title="Mid-range">₹₹</span> ›
                </div>
            </a>
        </div>
    </div>
</Layout>
